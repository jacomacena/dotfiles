#!/usr/bin/env bash

set -euo pipefail

connected_outputs() {
    xrandr --query | awk '$2 == "connected" { print $1 }'
}

internal_output() {
    connected_outputs | awk '/^(eDP|LVDS)/ { print; exit }'
}

external_output() {
    connected_outputs | awk '!/^(eDP|LVDS)/ { print; exit }'
}

internal="$(internal_output)"
external="$(external_output)"

[ -n "$internal" ] || exit 0

if [ -n "$external" ]; then
    xrandr --output "$internal" --primary --auto --output "$external" --auto --right-of "$internal"
else
    xrandr --output "$internal" --primary --auto
fi

if command -v bspc >/dev/null 2>&1; then
    if [ -n "$external" ]; then
        bspc monitor "$internal" -d 1 2 3 4 5 6
        bspc monitor "$external" -d 7 8 9 0
    else
        bspc monitor "$internal" -d 1 2 3 4 5 6 7 8 9 0
    fi
fi
